{
  "name": "mydash",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "test:unit": "vitest run --dir packages/backend/src --dir packages/shared/src",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.1.10"
  }
}
