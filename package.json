{
  "name": "mydash",
  "version": "1.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun --filter '*' typecheck",
    "clean": "bun --filter '*' clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "bun run packages/backend/src/main.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node-telegram-bot-api": "^0.64.15",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.1.10"
  }
}
