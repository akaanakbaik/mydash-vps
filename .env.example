# ─── Required ───────────────────────────────────────────────
DATABASE_URL=postgresql://mydash:mydash_prod_2024@localhost:5432/mydash
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-random-64-char-string

# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ─── PostgreSQL ─────────────────────────────────────────────
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_MIGRATION_ENABLED=true

# ─── Redis ──────────────────────────────────────────────────
REDIS_MAX_RETRIES=5
REDIS_RETRY_DELAY_MS=5000
REDIS_KEY_PREFIX=mydash:

# ─── Authentication ─────────────────────────────────────────
SESSION_LIFETIME_HOURS=24
MAX_LOGIN_ATTEMPTS=5
BRUTE_FORCE_COOLDOWN_MS=300000
PASSWORD_MIN_LENGTH=12

# ─── Security ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
ENCRYPTION_ENABLED=true

# ─── Notification ───────────────────────────────────────────
NOTIFICATION_ENABLED=true
NOTIFICATION_WORKER_COUNT=2
NOTIFICATION_MAX_RETRY=5
NOTIFICATION_COOLDOWN_MS=600000
NOTIFICATION_RATE_LIMIT_PER_MINUTE=10
AI_TIMEOUT_SECONDS=32

# ─── Monitoring ─────────────────────────────────────────────
CPU_SAMPLING_MS=1000
MEMORY_SAMPLING_MS=2000
DISK_SAMPLING_MS=5000
NETWORK_SAMPLING_MS=1000
SNAPSHOT_INTERVAL_MS=300000

# ─── Tunnel ────────────────────────────────────────────────
TUNNEL_PRIMARY_PROVIDER=instatunnel
TUNNEL_FALLBACK_PROVIDER=localtunnel
TUNNEL_HEALTH_CHECK_MS=30000
TUNNEL_MAX_RETRY=5
TUNNEL_AUTO_RECONNECT=true

# ─── AI (Optional) ──────────────────────────────────────────
AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
